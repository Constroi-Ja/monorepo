{
  "expo": {
    "name": "ConstróiJá",
    "slug": "constroija",
    "version": "1.0.0",
    "scheme": "constroija",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#f97316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.constroija.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Permitir acesso à câmera para foto de perfil e documentos.",
        "NSPhotoLibraryUsageDescription": "Permitir acesso à galeria para escolher imagens.",
        "NSPhotoLibraryAddUsageDescription": "Permitir salvar imagens na galeria."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#f97316"
      },
      "package": "com.constroija.app",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso à galeria para foto de perfil.",
          "cameraPermission": "Permitir acesso à câmera para tirar fotos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#f97316"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "constroija-app"
      }
    }
  }
}
