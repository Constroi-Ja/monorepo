# Email Configuration
# Em dev, EMAIL_BACKEND padrão é console (imprime no terminal). Para usar Gmail em dev,
# descomente EMAIL_BACKEND e preencha as credenciais abaixo.
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=contato.constroija@gmail.com
EMAIL_HOST_PASSWORD=sua-senha-de-app-gmail
DEFAULT_FROM_EMAIL=contato.constroija@gmail.com

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Django Settings Module
DJANGO_SETTINGS_MODULE=config.settings.development

# Cloudinary — https://cloudinary.com/console
